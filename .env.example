# ============================================================
# AI Video Matrix - Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=matrix
POSTGRES_PASSWORD=CHANGE_ME_pg_password
POSTGRES_DB=ai_video_matrix
DATABASE_URL=postgresql+asyncpg://matrix:CHANGE_ME_pg_password@postgres:5432/ai_video_matrix

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=videos

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=matrix
RABBITMQ_DEFAULT_PASS=CHANGE_ME_rmq_password
RABBITMQ_URL=amqp://matrix:CHANGE_ME_rmq_password@rabbitmq:5672/

# --- LLM API ---
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-CHANGE_ME
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=sk-CHANGE_ME

# --- AI Video Generation API ---
# Kling AI API (https://app.klingai.com/cn/dev/document-api/)
# China servers: https://api.klingai.com
# Overseas servers: https://api-singapore.klingai.com
KLING_BASE_URL=https://api.klingai.com
KLING_ACCESS_KEY=CHANGE_ME
KLING_SECRET_KEY=CHANGE_ME
JIMENG_API_KEY=CHANGE_ME
JIMENG_BASE_URL=https://api.jimeng.jianying.com

# --- TTS (CosyVoice) ---
COSYVOICE_ENDPOINT=http://cosyvoice:8000

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_n8n_password

# --- MoneyPrinterTurbo ---
MPT_PORT=8501

# --- Content Services ---
CONTENT_PLANNER_URL=http://content-planner:8000
VIDEO_MUTATOR_URL=http://video-mutator:8000
CONTENT_ROUTER_URL=http://content-router:8000

# --- Proxy Pool ---
PROXY_POOL_URL=
PROXY_POOL_API_KEY=

# --- Grafana ---
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_password
